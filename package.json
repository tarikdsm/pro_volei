{
  "name": "pro-volei",
  "version": "1.1.0",
  "description": "Pró Volei — jogo de vôlei 3D no browser, humano vs computador",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run check && vite build && gh-pages -d dist -m 'Deploy do Pró Volei no GitHub Pages'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:perf": "playwright test tests/e2e/performance.spec.ts",
    "perf:baseline": "playwright test tests/e2e/performance.spec.ts",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.1",
    "@types/three": "^0.185.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
